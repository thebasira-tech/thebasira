generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  EQUITY
  ETF
  DEBT
}

model Security {
  id        Int       @id @default(autoincrement())
  symbol    String    @unique
  name      String
  assetType AssetType
  sector    String?
  csiStatus String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  dailyPrices  DailyPrice[]
  ohlcvBars    OhlcvBar[]
  newsMentions NewsMention[] @relation("SecurityNewsMentions")
  aliases SecurityAlias[]
}

model DailyPrice {
  id        Int      @id @default(autoincrement())
  symbol    String
  date      DateTime
  open      Float?
  high      Float?
  low       Float?
  close     Float?
  volume    Float?
  value     Float?
  marketCap Float?
  high52w   Float?
  low52w    Float?
  createdAt DateTime @default(now())

  security Security @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, date])
  @@index([date])
}

model OhlcvBar {
  id        Int      @id @default(autoincrement())
  symbol    String
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float?
  createdAt DateTime @default(now())

  security Security @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, date])
  @@index([symbol, date])
  @@index([date])
}

model IndexValue {
  id        Int      @id @default(autoincrement())
  symbol    String
  name      String
  date      DateTime
  value     Float
  changePct Float?
  createdAt DateTime @default(now())

  @@unique([symbol, date])
  @@index([date])
}

model IngestionRun {
  id        String    @id @default(cuid())
  job       String
  status    String // "STARTED" | "SUCCESS" | "FAILED"
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  meta      Json?

  @@index([job, startedAt])
}

model RecentlyViewedSymbol {
  symbol    String   @id
  views7d   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model NewsSource {
  id        String   @id @default(cuid())
  name      String
  homepage  String?
  feedUrl   String   @unique
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles NewsArticle[]
}

model NewsArticle {
  id       String     @id @default(cuid())
  sourceId String
  source   NewsSource @relation(fields: [sourceId], references: [id])

  title       String
  url         String    @unique
  publishedAt DateTime?
  summary     String?
  imageUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mentions NewsMention[]
}

model NewsMention {
  id        String      @id @default(cuid())
  articleId String
  article   NewsArticle @relation(fields: [articleId], references: [id])

  symbol   String
  security Security @relation("SecurityNewsMentions", fields: [symbol], references: [symbol])

  createdAt DateTime @default(now())

  @@unique([articleId, symbol])
  @@index([symbol, createdAt])
}

model SecurityAlias {
  id     String @id @default(cuid())
  symbol String
  alias  String

  security Security @relation(fields: [symbol], references: [symbol])

  @@unique([symbol, alias], name: "symbol_alias")
}


